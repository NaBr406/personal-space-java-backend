# 后端端口
PORT=3001

# 环境名
APP_ENV=prod

# 建议这三个一起改，保持路径一致
APP_DATA_DIR=/var/lib/personal-space-java-backend
APP_DB_PATH=/var/lib/personal-space-java-backend/personal-space-java.db
APP_UPLOAD_DIR=/var/lib/personal-space-java-backend/uploads

# 仅首次自动创建超管时生效
ADMIN_PASSWORD=change-me-before-first-start
APP_SUPER_ADMIN_USERNAME=NaBr406
APP_SUPER_ADMIN_NICKNAME=NaBr406

# 可选：限制只监听本机，顺手加一点 JVM 内存配置
JAVA_OPTS=-Dserver.address=127.0.0.1 -Xms256m -Xmx512m
